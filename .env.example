# ── Provider ──────────────────────────────────────────────────────────────────
# "groq" (recommended, generous free tier) or "openrouter"
RISK_MONITOR_PROVIDER=groq

# Groq — free tier: 30 req/min, 14,400 req/day
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenRouter — fallback, needs credits for reliable use
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Models ────────────────────────────────────────────────────────────────────
# Groq free models (default):
RISK_MONITOR_MODEL_TRIAGE=llama-3.1-8b-instant
RISK_MONITOR_MODEL_SPECIALIST=llama-3.3-70b-versatile
RISK_MONITOR_MODEL_JUDGE=llama-3.3-70b-versatile

# OpenRouter alternatives (uncomment if PROVIDER=openrouter):
# RISK_MONITOR_MODEL_SPECIALIST=deepseek/deepseek-chat
# RISK_MONITOR_MODEL_JUDGE=deepseek/deepseek-chat

# ── Tuning ────────────────────────────────────────────────────────────────────
RISK_MONITOR_TRIAGE_THRESHOLD=20
RISK_MONITOR_MAX_DIFF_TOKENS=12000
RISK_MONITOR_DB_PATH=./risk_monitor.db
RISK_MONITOR_SENSITIVE_PATHS=auth,payments,migrations,secrets,billing
